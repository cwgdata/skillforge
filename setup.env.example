# SkillForge — copy to setup.env and fill in (setup.env is gitignored)
export DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
export DATABRICKS_WORKSPACE_ID=<the ?o= workspace id>
export SQL_WAREHOUSE_ID=<serverless warehouse id>     # pipeline UC reads/writes
export DATABRICKS_WAREHOUSE_ID=$SQL_WAREHOUSE_ID      # app SQL (same warehouse is fine)
export SKILLFORGE_CATALOG=skillforge
export SKILLFORGE_SCHEMA=core
export AI_GATEWAY_URL=https://$DATABRICKS_WORKSPACE_ID.ai-gateway.cloud.databricks.com/mlflow/v1
